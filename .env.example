# Required
ATTIO_API_KEY=your_api_key_here

# Optional
ATTIO_BASE_URL=https://api.attio.com
ATTIO_TIMEOUT_MS=30000
ATTIO_RETRY_ATTEMPTS=3

# Transport (stdio | http)
MCP_TRANSPORT=stdio

# HTTP Transport Configuration
MCP_PORT=3000
MCP_HOST=127.0.0.1

# Authentication (for remote/http transport)
MCP_AUTH_TOKEN=

# CORS - comma separated list of allowed origins (empty = allow all)
MCP_ALLOWED_ORIGINS=

# Session Management
MCP_SESSION_TTL_SECONDS=3600
MCP_MAX_SESSIONS=1000

# Logging
LOG_LEVEL=info
